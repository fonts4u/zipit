{
  "version": 2,
  "name": "website-to-zip",
  "env": {
    "NODE_ENV": "production",
    "AWS_LAMBDA_JS_RUNTIME": "nodejs20.x",
    "CRAWL_MAX_DEPTH": "1",
    "CRAWL_MAX_PAGES": "10",
    "ASSET_CONCURRENCY": "6",
    "RATE_LIMIT_MAX": "3",
    "RATE_LIMIT_WINDOW_MS": "60000",
    "PAGE_TIMEOUT_MS": "25000",
    "CRAWL_TIMEOUT_MS": "55000"
  },
  "functions": {
    "api/download.js": {
      "memory": 2048,
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/download",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "POST, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/download",
      "destination": "/api/download.js"
    },
    {
      "source": "/api/health",
      "destination": "/api/health.js"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1"
    }
  ]
}